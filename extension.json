{
  "name": "PageToGitHub",
  "author": "[https://www.lucamauri.com/ Luca Mauri]",
  "url": "https://github.com/lucamauri/PageToGitHub",
  "description": "Allow the transport of page content to GitHub on page save",
  "version": "2.1.0",
  "requires": {
    "MediaWiki": ">= 1.42.0",
    "platform": {
      "php": ">= 8.1.0"
    }
  },
  "license-name": "GPL-2.0-or-later",
  "type": "hook",
  "manifest_version": 2,
  "AutoloadClasses": {
    "PageToGitHubHooks": "PageToGitHub.php",
    "PageToGitHubSpecial": "includes/P2GSpecial.php"
  },
  "Hooks": {
    "PageSaveComplete": "PageToGitHubHooks"
  },
  "HookHandlers": {
    "PageToGitHubHooks": {
      "class": "PageToGitHubHooks",
      "services": ["ConfigFactory"]
    }
  },
  "config": {
    "P2GIgnoreMinor": {
      "description": "Ignore changes if they are minor",
      "descriptionmsg": "p2g-config-ignoreminor",
      "value": true
    },
    "P2GNameSpace": {
      "description": "Label of the namespace to check",
      "descriptionmsg": "p2g-config-namespace",
      "value": null
    },
    "P2GOwner": {
      "description": "Name of the owner of the repository",
      "descriptionmsg": "p2g-config-owner",
      "value": null
    },
    "P2GRepo": {
      "description": "Name of the repository where to save the files",
      "descriptionmsg": "p2g-config-repo",
      "value": null
    },
    "P2GKeyword": {
      "description": "Optional keyword to include selected page only in the transport",
      "descriptionmsg": "p2g-config-keyword",
      "value": ""
    },
    "P2GAddKeyword": {
      "description": "Add keyword to file name",
      "descriptionmsg": "p2g-config-addkeyword",
      "value": false
    },
    "P2GAuthToken": {
      "description": "Personal GitHub token",
      "descriptionmsg": "p2g-config-authtoken",
      "value": null
    }
  },
  "ConfigRegistry": {
    "PageToGitHub": "GlobalVarConfig::newInstance"
  },
  "SpecialPages": {
    "PageToGitHub": {
      "class": "PageToGitHubSpecial",
      "services": ["ConfigFactory"]
    }
  },
  "MessagesDirs": {
    "PageToGitHub": ["i18n"]
  }
}
